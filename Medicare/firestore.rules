rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isDoctor() {
      return hasRole('doctor');
    }

    // ── users/{uid} ──────────────────────────────────────────────────────────
    // A user may read/write only their own document.
    // Admins may read any user document.

    match /users/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid);
    }

    // ── patients ─────────────────────────────────────────────────────────────
    // Admins have full access.
    // Doctors may read patients.

    match /patients/{patientId} {
      allow read:  if isAdmin() || isDoctor();
      allow write: if isAdmin();

      match /records/{recordId} {
        allow read:  if isAdmin() || isDoctor();
        allow write: if isAdmin() || isDoctor();
      }

      match /vitals/{vitalId} {
        allow read:  if isAdmin() || isDoctor();
        allow write: if isAdmin() || isDoctor();
      }
    }

    // ── appointments ─────────────────────────────────────────────────────────
    // Admins have full access.
    // Doctors may read appointments.

    match /appointments/{appointmentId} {
      allow read:  if isAdmin() || isDoctor();
      allow write: if isAdmin();
    }

    // ── doctors ──────────────────────────────────────────────────────────────
    // Admins have full access.
    // A doctor may read their own record.

    match /doctors/{doctorId} {
      allow read:  if isAdmin() || isDoctor();
      allow write: if isAdmin();
    }

    // ── pharmacy ─────────────────────────────────────────────────────────────
    // Admins have full access. Authenticated users can read (for cart/browsing).

    match /pharmacy/{itemId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── prescriptions ────────────────────────────────────────────────────────
    // Doctors create (via patient_detail_screen dual-write).
    // Pharmacy staff (admin/receptionist) read and update status.
    // Clinical staff (doctors/nurses) can read to see fulfillment status.

    match /prescriptions/{rxId} {
      allow read:   if isAdmin() || isDoctor() || hasRole('nurse') || hasRole('receptionist');
      allow create: if isAdmin() || isDoctor();
      allow update: if isAdmin() || hasRole('receptionist');
    }

    // ── smsLog ───────────────────────────────────────────────────────────────
    // Authenticated staff may create log entries. Admins may read all.

    match /smsLog/{logId} {
      allow read:   if isAdmin();
      allow create: if isAuthenticated();
    }

    // ── smsTemplates ─────────────────────────────────────────────────────────
    // Admins have full access.

    match /smsTemplates/{templateId} {
      allow read, write: if isAdmin();
    }

    // ── notifications ────────────────────────────────────────────────────────
    // A user may read their own notifications. Admins may write.

    match /notifications/{notifId} {
      allow read:  if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }

    // ── shifts ───────────────────────────────────────────────────────────────
    // Admins have full access. All authenticated staff may read.

    match /shifts/{shiftId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── invoices ─────────────────────────────────────────────────────────────
    // Admins and receptionists have full access.
    // Doctors may read invoices linked to their patients.

    match /invoices/{invoiceId} {
      allow read:   if isAdmin() || hasRole('receptionist') || isDoctor();
      allow create: if isAdmin() || hasRole('receptionist');
      allow update: if isAdmin() || hasRole('receptionist');
    }

    // ── All other collections ────────────────────────────────────────────────
    // Deny everything not explicitly allowed above.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
